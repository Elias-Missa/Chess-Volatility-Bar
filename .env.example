# Path to the Stockfish binary.
# Leave blank to let chess_vol auto-detect (tries `shutil.which`, common install paths).
# Examples:
#   Windows : STOCKFISH_PATH=C:\Program Files\Stockfish\stockfish.exe
#   macOS   : STOCKFISH_PATH=/opt/homebrew/bin/stockfish
#   Linux   : STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_PATH=
